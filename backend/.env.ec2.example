# DevStore Backend - EC2 Environment Configuration
# Copy this file to .env and fill in your values

# ==================== Database Configuration ====================
DATABASE_URL=postgresql://username:password@your-rds-endpoint:5432/devstore
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== Redis (ElastiCache) Configuration ====================
# For ElastiCache, use the Primary Endpoint from AWS Console
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_SOCKET_TIMEOUT=5

# ==================== AWS Configuration ====================
AWS_REGION=us-east-1
# For EC2 with IAM role, leave these empty
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==================== OpenSearch Configuration ====================
OPENSEARCH_HOST=your-opensearch-endpoint.us-east-1.es.amazonaws.com
OPENSEARCH_PORT=443
OPENSEARCH_USE_SSL=true
OPENSEARCH_INDEX_NAME=devstore_resources

# ==================== Bedrock Configuration ====================
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# ==================== S3 Configuration ====================
S3_BUCKET_BOILERPLATE=devstore-boilerplate-prod
S3_BUCKET_CRAWLER_DATA=devstore-crawler-data-prod

# ==================== API Configuration ====================
API_RATE_LIMIT=100
API_TIMEOUT=30
CORS_ORIGINS=["https://yourdomain.com","http://localhost:3000"]

# ==================== Server Configuration ====================
ENVIRONMENT=production
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4

# ==================== Security ====================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
