# Database Configuration
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://devstore-admin:your_password@your-rds-endpoint.region.rds.amazonaws.com:5432/devstore
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Elasticache Configuration
REDIS_HOST=your-redis-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_SOCKET_TIMEOUT=5

# AWS Configuration
AWS_REGION=ap-northeast-3
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# OpenSearch Configuration
OPENSEARCH_HOST=your-opensearch-endpoint.region.es.amazonaws.com
OPENSEARCH_PORT=443
OPENSEARCH_USE_SSL=true
OPENSEARCH_INDEX_NAME=devstore_resources

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# S3 Configuration
S3_BUCKET_BOILERPLATE=devstore-boilerplate-templates
S3_BUCKET_CRAWLER_DATA=devstore-crawler-data

# API Configuration
API_RATE_LIMIT=100
API_TIMEOUT=30

# Ingestion API Keys
INGESTION_GITHUB_API_TOKEN=your_github_token_here

# Ingestion SQS Configuration
INGESTION_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/devstore-resource-ingestion-queue

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
