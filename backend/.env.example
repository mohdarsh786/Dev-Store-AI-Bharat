# ==================== Database Configuration ====================
DATABASE_URL=postgresql://user:password@localhost:5432/devstore
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== AWS Configuration ====================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_account_id_here
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ==================== OpenSearch Configuration ====================
# For AWS OpenSearch Service, use format: https://your-domain.region.es.amazonaws.com
# For OpenSearch Serverless, use format: https://xxxxx.region.aoss.amazonaws.com
OPENSEARCH_HOST=your-opensearch-endpoint.region.es.amazonaws.com
OPENSEARCH_PORT=443
OPENSEARCH_USE_SSL=true
OPENSEARCH_INDEX_NAME=devstore_resources

# ==================== Bedrock Configuration ====================
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_CLAUDE_ARN=arn:aws:bedrock:region:account:inference-profile/model-id

# ==================== S3 Configuration ====================
S3_BUCKET_BOILERPLATE=devstore-boilerplate-templates
S3_BUCKET_CRAWLER_DATA=devstore-crawler-data

# ==================== Redis Configuration ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_SOCKET_TIMEOUT=5

# ==================== API Configuration ====================
API_RATE_LIMIT=100
API_TIMEOUT=30
CORS_ORIGINS=["http://localhost:3000"]

# ==================== Ingestion Configuration ====================
INGESTION_GITHUB_API_TOKEN=your_github_token_here
INGESTION_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/devstore-resource-ingestion-queue
INGESTION_LOCK_KEY=ingestion:lock
INGESTION_LOCK_TTL_SECONDS=7200
INGESTION_STATUS_TTL_SECONDS=86400
INGESTION_SCHEDULE_HOURS=12
RANKING_SCHEDULE_HOUR_UTC=3
CRAWLER_SNAPSHOT_PREFIX=snapshots

# ==================== Server Configuration ====================
ENVIRONMENT=development
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WORKERS=4

# ==================== Security ====================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
