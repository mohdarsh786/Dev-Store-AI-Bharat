# ==================== Database Configuration ====================
# Get your Neon database URL from: https://console.neon.tech/app/projects
DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/database_name?sslmode=require
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ==================== AWS Configuration ====================
# Get these from AWS IAM Console: https://console.aws.amazon.com/iam/home#/users
AWS_REGION=your-aws-region
AWS_ACCOUNT_ID=your-aws-account-id
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ==================== Bedrock (Amazon Nova) ====================
# Use your specific AWS region and account ID in the ARN
BEDROCK_MODEL_ID=arn:aws:bedrock:your-region:your-account-id:inference-profile/apac.amazon.nova-micro-v1:0
BEDROCK_REGION=your-bedrock-region
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# System prompt for the AI assistant
SYSTEM_PROMPT="You are the DevStore AI Assistant. Always use the provided context to answer. If asked in English, reply in English. If asked in Hinglish, reply in Hinglish. Describe technical tools like OpenMed in detail based on the context."

# ==================== Pinecone (Optimized Search) ====================
# Get your API key from: https://app.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=your-pinecone-index-name
PINECONE_ENVIRONMENT=your-pinecone-environment

# ==================== Redis Configuration ====================
# Get these from AWS ElastiCache Console: https://console.aws.amazon.com/elasticache/
REDIS_HOST=your-redis-host.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-if-any
REDIS_DB=0
REDIS_POOL_SIZE=50

# ==================== S3 Configuration ====================
# Create these buckets in AWS S3 Console: https://console.aws.amazon.com/s3/
S3_BUCKET_BOILERPLATE=your-boilerplate-bucket-name
S3_BUCKET_CRAWLER_DATA=your-crawler-data-bucket-name

# ==================== Server & Security ====================
# Generate a secure secret key
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ENVIRONMENT=development
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
