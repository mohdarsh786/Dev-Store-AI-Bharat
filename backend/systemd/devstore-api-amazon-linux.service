[Unit]
Description=DevStore FastAPI Application
After=network.target

[Service]
Type=simple
User=ec2-user
WorkingDirectory=/home/ec2-user/Dev-Store-AI-Bharat/backend
Environment="PATH=/home/ec2-user/Dev-Store-AI-Bharat/backend/venv/bin"
ExecStart=/home/ec2-user/Dev-Store-AI-Bharat/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
