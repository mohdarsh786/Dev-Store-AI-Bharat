:: в”Җв”Җв”Җ Step 2: .env.local check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo  [2/4] Checking environment configuration...
if not exist ".env.local" (
    echo.
    echo  [WARNING] .env.local not found!
    echo.
    echo  Required frontend config:
    echo    - BACKEND_URL=http://localhost:8000
    echo    - AUTH_SECRET=your-nextauth-secret-key
    echo.
    echo  The app will start with demo data only.
    echo.
    choice /C YN /M "  Continue anyway? (Y=Yes, N=Exit)"
    if !errorlevel! equ 2 exit /b 1
    echo.
) else (
    echo        .env.local found. OK.
    echo.
)

:: в”Җв”Җв”Җ Step 3: npm install в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo  [3/4] Installing dependencies...
if not exist "node_modules" (
    echo        node_modules not found. Running npm install...
    echo.
    npm install
    if !errorlevel! neq 0 (
        echo.
        echo  [ERROR] npm install failed. Check your Node.js installation.
        pause
        exit /b 1
    )
    echo.
    echo        Dependencies installed successfully.
) else (
    echo        node_modules exists. Skipping install.
)
echo.

